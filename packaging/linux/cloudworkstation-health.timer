[Unit]
Description=Prism Health Check Timer
Documentation=https://github.com/scttfrdmn/prism
Requires=prism.service

[Timer]
# Run health check every 5 minutes
OnCalendar=*:0/5
Persistent=true
RandomizedDelaySec=30s

# Ensure health check runs only when main service is active
ConditionPathExists=/run/systemd/system/prism.service

[Install]
WantedBy=timers.target