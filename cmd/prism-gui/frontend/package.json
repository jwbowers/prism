{
  "name": "prism-gui",
  "version": "0.35.3",
  "description": "Prism Professional GUI Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node tests/e2e/run-single.js",
    "test:e2e:fresh": "scripts/run-fresh-tests.sh",
    "test:e2e:fast": "playwright test --config=playwright.parallel.config.js --project=ui-chromium --project=ui-webkit --project=read-chromium --project=read-webkit --workers=4",
    "test:e2e:serial": "playwright test --config=playwright.parallel.config.js --project=write-chromium --project=write-webkit --project=storage-chromium --project=storage-webkit --workers=1",
    "test:e2e:all": "npm run test:e2e:fast && npm run test:e2e:serial",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:aws": "playwright test --config=playwright.aws.config.js",
    "test:e2e:aws:instances": "playwright test --config=playwright.aws.config.js instance-workflows.spec.ts",
    "test:e2e:aws:hibernation": "playwright test --config=playwright.aws.config.js hibernation-workflows.spec.ts",
    "test:e2e:aws:storage": "playwright test --config=playwright.aws.config.js storage-workflows.spec.ts",
    "test:all": "npm run test:unit && npm run test:e2e",
    "playwright:install": "playwright install",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.0.1",
    "msw": "^2.6.4",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "prism",
    "academic",
    "research",
    "aws",
    "gui"
  ],
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.1.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.2",
    "xterm": "^5.3.0",
    "zod": "^4.3.6"
  }
}
