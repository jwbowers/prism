{
  "name": "prism-gui",
  "version": "0.7.5",
  "description": "Prism Professional GUI Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node tests/e2e/run-single.js",
    "test:e2e:fresh": "scripts/run-fresh-tests.sh",
    "test:e2e:fast": "playwright test --config=playwright.parallel.config.js --project=ui-chromium --project=ui-webkit --project=read-chromium --project=read-webkit --workers=3",
    "test:e2e:serial": "playwright test --config=playwright.parallel.config.js --project=write-chromium --project=write-webkit --project=storage-chromium --project=storage-webkit --workers=1",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:aws": "playwright test --config=playwright.aws.config.js",
    "test:e2e:aws:instances": "playwright test --config=playwright.aws.config.js instance-workflows.spec.ts",
    "test:e2e:aws:hibernation": "playwright test --config=playwright.aws.config.js hibernation-workflows.spec.ts",
    "test:e2e:aws:storage": "playwright test --config=playwright.aws.config.js storage-workflows.spec.ts",
    "test:visual": "percy exec -- playwright test --config=playwright.visual.config.js",
    "test:all": "npm run test:unit && npm run test:e2e",
    "playwright:install": "playwright install",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.json",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint"
  },
  "devDependencies": {
    "@percy/cli": "^1.30.1",
    "@percy/playwright": "^1.0.6",
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.23",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.0.1",
    "lodash": "^4.17.21",
    "msw": "^2.6.4",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "prism",
    "academic",
    "research",
    "aws",
    "gui"
  ],
  "dependencies": {
    "@cloudscape-design/components": "^3.0.1099",
    "@cloudscape-design/design-tokens": "^3.0.61",
    "@cloudscape-design/global-styles": "^1.0.45",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "xterm": "^5.3.0"
  }
}
